{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@libs/*": ["projects/service-nutrivae-ui/src/lib/*"],
      "@libs": ["projects/service-nutrivae-ui/src/lib"],
      "@libs/api": ["projects/service-nutrivae-ui/src/lib/api"],
      "@components/*": ["projects/service-nutrivae-ui/src/components/*"],
      "@components": ["projects/service-nutrivae-ui/src/components"],
      "@components/forms": ["projects/service-nutrivae-ui/src/components/forms"]
    }
  }
}
